# =============================================================
# arXivisual Backend — Environment Variables
# =============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# =============================================================

# ---------------------------
# LLM / AI
# ---------------------------

# ---------------------------
# OpenAI API
# ---------------------------
# REQUIRED: All LLM calls use OpenAI Responses API in this project.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional model overrides
# OPENAI_MODEL=gpt-5.4
# OPENAI_CONTEXT7_MODEL=gpt-5.4-mini
# OPENAI_REASONING_EFFORT=low

# ---------------------------
# Storage Mode
# ---------------------------
# "local" (default) — files stored in ./media/videos/
# "r2" — Cloudflare R2 cloud storage
STORAGE_MODE=local

# ---------------------------
# Cloudflare R2 (only needed when STORAGE_MODE=r2)
# ---------------------------
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_BUCKET=arxiviz-videos
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_PUBLIC_URL=https://videos.arxiviz.org

# ---------------------------
# Modal.com
# Run `modal token new` to get your token.
# ---------------------------
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
# Use "local" unless you have Modal tokens configured.
RENDER_MODE=local
# Max parallel local renders (lower = more stable on laptops)
# RENDER_CONCURRENCY=1
# Per-visualization hard timeout in worker (seconds)
# RENDER_TIMEOUT_SECONDS=1200
# Manim subprocess timeout (seconds)
# MANIM_SUBPROCESS_TIMEOUT_SECONDS=900

# ---------------------------
# API Server
# ---------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ---------------------------
# arXiv API throttling (optional)
# ---------------------------
# Minimum spacing between metadata requests to avoid 429s
# ARXIV_MIN_INTERVAL_SECONDS=3.0
# Minimum spacing between topic search requests
# ARXIV_SEARCH_MIN_INTERVAL_SECONDS=8.0
# Metadata fetch retry budget and exponential backoff base
# ARXIV_META_MAX_RETRIES=6
# Topic search retries are intentionally lower to avoid amplifying 429 rate limits
# ARXIV_SEARCH_MAX_RETRIES=1
# ARXIV_BACKOFF_BASE_SECONDS=3.0
# Cooldown after an arXiv 429 response
# ARXIV_429_COOLDOWN_SECONDS=300
# Topic search recency window and sorting
# ARXIV_TOPIC_RECENT_YEARS=3
# ARXIV_TOPIC_SORT_BY=submittedDate
# Optional custom User-Agent for arXiv API requests
# ARXIV_USER_AGENT=arXiviz/0.1 (+you@example.com)

# ---------------------------
# Windows TeX tools (optional)
# ---------------------------
# If MathTex fails due missing latex/dvisvgm, point to MiKTeX bin folder.
# MIKTEX_BIN_DIR=C:\\Users\\<you>\\AppData\\Local\\Programs\\MiKTeX\\miktex\\bin\\x64
